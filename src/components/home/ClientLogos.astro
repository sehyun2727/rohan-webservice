---
import { shippers, retailers } from '../../data/clients.js';
---

<section class="clients section" aria-label="주요 거래처">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Clients & Partners</span>
      <h2 class="section-title">주요 거래처</h2>
      <p class="section-desc">
        설립 이래 전국 80여 개 업체의 대형마트 납품·수송을 대행하며<br />
        신뢰받는 콜드체인 파트너로 성장해 왔습니다.
      </p>
    </div>

    <div class="clients__groups">

      <div class="clients__group">
        <p class="clients__group-label">화주사</p>
        <div class="clients__row">
          {shippers.map((c) => (
            <div class="client-badge client-badge--wide">
              <span class="client-badge__name client-badge__name--always">{c.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="clients__divider" aria-hidden="true"></div>

      <div class="clients__group">
        <p class="clients__group-label">납품처</p>
        <div class="clients__row">
          {retailers.map((c) => (
            <div class="client-badge">
              <img
                src={c.logo}
                alt={c.name}
                class="client-badge__logo"
                onerror={`this.style.display='none';this.nextElementSibling.style.display='inline'`}
              />
              <span class="client-badge__name" style="display:none">{c.name}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .clients {
    background: #fff;
    border-top: 1px solid var(--color-border);
  }

  .clients__groups {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .clients__group-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    text-align: center;
  }

  .clients__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
  }

  .clients__divider {
    height: 1px;
    background: var(--color-border);
    margin-inline: auto;
    width: 60%;
  }

  /* 공통 배지 */
  .client-badge {
    min-width: 110px;
    height: 52px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.9rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .client-badge:hover {
    border-color: var(--color-primary-light);
    box-shadow: var(--shadow-sm);
  }

  /* 화주사 — 텍스트가 더 길어서 min-width 넉넉하게 */
  .client-badge--wide {
    min-width: 140px;
  }

  .client-badge__logo {
    max-height: 32px;
    max-width: 90px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.55;
    transition: filter var(--transition), opacity var(--transition);
  }

  .client-badge:hover .client-badge__logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  .client-badge__name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* 로고 없이 항상 텍스트를 표시하는 배지 */
  .client-badge__name--always {
    display: inline !important;
  }

  @media (max-width: 540px) {
    .client-badge { min-width: 90px; }
    .client-badge--wide { min-width: 120px; }
    .client-badge__name { font-size: 0.75rem; }
  }
</style>
