---
import { shippers, retailers } from '../../data/clients.js';
---

<section class="clients section" aria-label="주요 거래처">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Clients & Partners</span>
      <h2 class="section-title">주요 거래처</h2>
      <p class="section-desc">
        국내 주요 식품·유통 기업과 함께합니다.
      </p>
    </div>

    <div class="clients__groups">
      <div class="clients__group">
        <p class="clients__group-label">화주사</p>
        <div class="clients__row">
          {shippers.map((c) => (
            <div class="client-badge">
              <img
                src={c.logo}
                alt={c.name}
                class="client-badge__logo"
                onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
              />
              <span class="client-badge__name" style="display:none">{c.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="clients__divider" aria-hidden="true"></div>

      <div class="clients__group">
        <p class="clients__group-label">납품처</p>
        <div class="clients__row">
          {retailers.map((c) => (
            <div class="client-badge">
              <img
                src={c.logo}
                alt={c.name}
                class="client-badge__logo"
                onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
              />
              <span class="client-badge__name" style="display:none">{c.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .clients {
    background: #fff;
    border-top: 1px solid var(--color-border);
  }

  .clients__groups {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .clients__group-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    text-align: center;
  }

  .clients__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .clients__divider {
    height: 1px;
    background: var(--color-border);
    margin-inline: auto;
    width: 60%;
  }

  /* Badge: shows logo image, fallback to text badge */
  .client-badge {
    min-width: 120px;
    height: 56px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .client-badge:hover {
    border-color: var(--color-primary-light);
    box-shadow: var(--shadow-sm);
  }

  .client-badge__logo {
    max-height: 36px;
    max-width: 100px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: filter var(--transition), opacity var(--transition);
  }

  .client-badge:hover .client-badge__logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* Text fallback when logo image is missing */
  .client-badge__name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-align: center;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .client-badge { min-width: 100px; }
  }
</style>
