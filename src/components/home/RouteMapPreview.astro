164.3 L 62.3,161.1 L 67.6,157.5 L 68.8,154.7 L 67.7,153.2 L 61.6,151.7 L 56.1,141.0 L 55.4,136.4 L 53.4,133.5 L 56.3,125.0 L 50.0,115.3 L 46.9,112.3 L 47.3,103.6 L 44.0,98.0 L 42.2,95.0 L 41.1,89.8 L 42.0,87.4 L 44.9,86.5 L 45.8,84.3 Z";

const routeNodes = [
  { label: '성남', x: 76.9, y: 114.5, hub: false },
  { label: '경기광주', x: 91.5, y: 113.8, hub: false },
  { label: '안성', x: 89.2, y: 149.0, hub: true },
  { label: '칠곡', x: 170.5, y: 233.6, hub: true },
  { label: '함안', x: 164.9, y: 294.0, hub: false },
  { label: '김해', x: 197.3, y: 297.7, hub: false },
  { label: '기장', x: 219.7, y: 296.3, hub: false },
