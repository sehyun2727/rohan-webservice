  { x1: 76.9, y1: 114.5, x2: 89.2, y2: 149.0 },
  { x1: 91.5, y1: 113.8, x2: 89.2, y2: 149.0 },
  { x1: 89.2, y1: 149.0, x2: 170.5, y2: 233.6 },
  { x1: 170.5, y1: 233.6, x2: 164.9, y2: 294.0 },
  { x1: 170.5, y1: 233.6, x2: 197.3, y2: 297.7 },
