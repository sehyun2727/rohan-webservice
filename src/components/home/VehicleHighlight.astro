---
import { vehicleFeatures, vehicleStats } from '../../data/vehicles.js';
---

<section class="vehicle-section section" aria-label="차량 경쟁력">
  <div class="container">
    <div class="vehicle-inner">

      <div class="vehicle-text" data-aos="fade-right">
        <span class="section-label">Our Fleet</span>
        <h2 class="section-title">차량 경쟁력</h2>
        <p class="vehicle-text__desc">
          직영 냉동탑차 약 <strong>{vehicleStats.count}대</strong>를 직접 관리합니다.<br />
          철저한 차량 관리와 최신 설비로 화물의 신선도를 지킵니다.
        </p>
        <a href="/vehicles" class="btn btn--outline vehicle-text__cta">차량 상세 보기</a>
      </div>

      <div class="vehicle-features" data-aos="fade-left" data-aos-delay="100">
        {vehicleFeatures.map((f) => (
          <div class="vf-item">
            <div class="vf-item__dot" aria-hidden="true"></div>
            <div class="vf-item__content">
              <strong class="vf-item__title">{f.title}</strong>
              <span class="vf-item__detail">{f.detail}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .vehicle-section {
    background: #fff;
  }

  .vehicle-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* Left text block */
  .vehicle-text .section-label { margin-bottom: 0.75rem; }

  .vehicle-text .section-title {
    margin-bottom: 1.25rem;
    text-align: left;
  }

  .vehicle-text__desc {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .vehicle-text__desc strong { color: var(--color-primary); }

  .vehicle-text__cta { align-self: flex-start; }

  /* Right feature grid */
  .vehicle-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .vf-item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .vf-item:hover {
    border-color: var(--color-primary-light);
    box-shadow: var(--shadow-sm);
  }

  .vf-item__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .vf-item__content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .vf-item__title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
  }

  .vf-item__detail {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .vehicle-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .vehicle-text .section-title { text-align: center; }
    .vehicle-text { text-align: center; }
    .vehicle-text__cta { width: 100%; }
  }

  @media (max-width: 480px) {
    .vehicle-features { grid-template-columns: 1fr; }
  }
</style>
