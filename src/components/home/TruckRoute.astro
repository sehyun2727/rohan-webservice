---
import koreaPts from '../../data/korea-outline.json';

const W = 500, H = 560;
const pts: number[][] = koreaPts as number[][];
const koreaPath = pts.map((pt, i) => {
  const x = +((pt[0] - 124.5) / 6 * W).toFixed(1);
  const y = +((38.8 - pt[1]) / 5.8 * H).toFixed(1);
  return `${i === 0 ? 'M' : 'L'}${x},${y}`;
}).join('') + 'Z';
---

<section class="tr-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Network</span>
      <h2 class="section-title">전국 물류 네트워크</h2>
      <p class="section-desc">수도권·영남·호남을 잇는 콜드체인 직영 노선</p>
    </div>

    <div class="tr-frame">
      <svg class="tr-svg" viewBox="0 0 500 560" role="img" aria-label="전국 물류 노선도">

        <!-- 한국 지도 윤곽 (실제 GeoJSON 좌표) -->
        <path class="kr" d={koreaPath} />

        <!-- 노선 배경선 -->
        <g class="rt-group">
          <!-- 수도권 접속 -->
          <path d="M184,130 L231,173"/>
          <path d="M245,148 L231,173"/>
          <path d="M285,141 L256,166 L231,173"/>
          <!-- 안성↔칠곡 두 평행선 (경부선 계열) -->
          <path d="M231,173 C260,210 295,245 325,271"/>
          <path d="M231,173 C248,222 285,252 325,271"/>
          <!-- 동해선 -->
          <path d="M365,101 L385,123 L344,193 L352,215 L325,271"/>
          <!-- 호남선 (안성→담양→광주→목포, 단일 루트) -->
          <path d="M231,173 C225,220 216,268 207,336 L196,351 L184,365 L158,385"/>
          <!-- 담양 분기 -->
          <path d="M207,336 L249,372 L266,373"/>
          <path d="M207,336 L301,349 L297,366"/>
          <!-- 칠곡 분기 -->
          <path d="M325,271 L404,268"/>
          <path d="M325,271 L354,320 L378,334 L381,349"/>
          <path d="M354,320 L348,345 L340,349"/>
          <!-- 칠곡↔함안 -->
          <path d="M325,271 C325,305 326,323 326,341"/>
          <!-- 함안 분기 -->
          <path d="M326,341 L366,344"/>
          <path d="M326,341 L348,345"/>
          <path d="M326,341 L301,349 L297,366"/>
        </g>

        <!-- 흐름 애니메이션 (점선 대시) -->
        <!-- 트럭1 노선: 안성→담양→진주 -->
        <path class="flow f1" d="M231,173 C228,215 218,270 207,336 C240,341 272,345 301,349"/>
        <!-- 트럭2 노선: 이천→안성→칠곡→함안→김해 -->
        <path class="flow f2" d="M245,148 L231,173 C265,215 295,245 325,271 L326,341 L366,344"/>
        <!-- 트럭3 노선: 안성→칠곡→진주 -->
        <path class="flow f3" d="M231,173 C265,215 295,245 325,271 C315,305 307,328 301,349"/>

        <!-- 트럭 1 (안성→담양→진주) -->
        <g class="truck t1">
          <path d="M-14,-4 L-2,-4 L-2,-7 L9,-7 L9,3 L-14,3 Z"/>
          <circle cx="-9" cy="4.5" r="2.5"/>
          <circle cx="4"  cy="4.5" r="2.5"/>
        </g>

        <!-- 트럭 2 (이천→안성→칠곡→함안→김해) -->
        <g class="truck t2">
          <path d="M-14,-4 L-2,-4 L-2,-7 L9,-7 L9,3 L-14,3 Z"/>
          <circle cx="-9" cy="4.5" r="2.5"/>
          <circle cx="4"  cy="4.5" r="2.5"/>
        </g>

        <!-- 트럭 3 (안성→칠곡→진주) -->
        <g class="truck t3">
          <path d="M-14,-4 L-2,-4 L-2,-7 L9,-7 L9,3 L-14,3 Z"/>
          <circle cx="-9" cy="4.5" r="2.5"/>
          <circle cx="4"  cy="4.5" r="2.5"/>
        </g>

        <!-- 일반 도시 (도트만) -->
        <circle class="cdot" cx="256" cy="166" r="3"/>
        <circle class="cdot" cx="344" cy="193" r="3"/>
        <circle class="cdot" cx="352" cy="215" r="3"/>
        <circle class="cdot" cx="354" cy="320" r="3"/>
        <circle class="cdot" cx="378" cy="334" r="3"/>
        <circle class="cdot" cx="348" cy="345" r="3"/>
        <circle class="cdot" cx="340" cy="349" r="3"/>
        <circle class="cdot" cx="249" cy="372" r="3"/>
        <circle class="cdot" cx="266" cy="373" r="3"/>
        <circle class="cdot" cx="297" cy="366" r="3"/>

        <!-- 레이블 있는 주요 도시 -->
        <g transform="translate(184,130)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-left" x="-8" y="4">인천</text>
        </g>
        <g transform="translate(245,148)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-right" x="8" y="4">이천</text>
        </g>
        <g transform="translate(285,141)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-right" x="8" y="4">원주</text>
        </g>
        <g transform="translate(365,101)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-right" x="8" y="4">강릉</text>
        </g>
        <g transform="translate(385,123)">
          <circle r="3.5" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-right" x="8" y="4">동해</text>
        </g>
        <g transform="translate(404,268)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-right" x="8" y="4">포항</text>
        </g>
        <g transform="translate(366,344)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-top" x="0" y="-9">김해</text>
        </g>
        <g transform="translate(381,349)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-right" x="8" y="4">부산</text>
        </g>
        <g transform="translate(301,349)">
          <circle r="5" fill="#fff" stroke="#1b4f8a" stroke-width="2"/>
          <text class="lbl lbl-left" x="-10" y="4">진주</text>
        </g>
        <g transform="translate(207,336)">
          <circle r="4.5" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-left" x="-9" y="4">담양</text>
        </g>
        <g transform="translate(196,351)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-left" x="-9" y="4">광주</text>
        </g>
        <g transform="translate(184,365)">
          <circle r="3.5" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-left" x="-9" y="4">나주</text>
        </g>
        <g transform="translate(158,385)">
          <circle r="4" fill="#fff" stroke="#1b4f8a" stroke-width="1.5"/>
          <text class="lbl lbl-left" x="-9" y="4">목포</text>
        </g>

        <!-- 안성 허브 (펄스) -->
        <g transform="translate(231,173)">
          <circle r="10" fill="none" stroke="#1b4f8a" stroke-width="1.5">
            <animate attributeName="r"       values="10;28" dur="2.5s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.5;0" dur="2.5s" repeatCount="indefinite"/>
          </circle>
          <circle r="7" fill="#fff" stroke="#1b4f8a" stroke-width="2.5"/>
          <circle r="3" fill="#1b4f8a"/>
          <text class="lbl hub-lbl lbl-top" x="0" y="-14">안성</text>
        </g>

        <!-- 칠곡 허브 (펄스) -->
        <g transform="translate(325,271)">
          <circle r="9" fill="none" stroke="#1b4f8a" stroke-width="1.2">
            <animate attributeName="r"       values="9;24"  dur="2.8s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.4;0" dur="2.8s" repeatCount="indefinite"/>
          </circle>
          <circle r="6" fill="#fff" stroke="#1b4f8a" stroke-width="2"/>
          <circle r="2.5" fill="#1b4f8a"/>
          <text class="lbl hub-lbl lbl-right" x="11" y="4">칠곡</text>
        </g>

        <!-- 함안 허브 (펄스) -->
        <g transform="translate(326,341)">
          <circle r="9" fill="none" stroke="#1b4f8a" stroke-width="1.2">
            <animate attributeName="r"       values="9;24"  dur="3s"   repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.4;0" dur="3s"   repeatCount="indefinite"/>
          </circle>
          <circle r="6" fill="#fff" stroke="#1b4f8a" stroke-width="2"/>
          <circle r="2.5" fill="#1b4f8a"/>
          <text class="lbl hub-lbl lbl-right" x="11" y="4">함안</text>
        </g>

      </svg>

    </div>
  </div>
</section>

<style>
  .tr-section {
    padding-block: var(--section-py);
    background: #fff;
    border-top: 1px solid rgba(27, 79, 138, 0.08);
  }

  .tr-frame {
    max-width: 560px;
    margin: 2.5rem auto 0;
  }

  .tr-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* 한국 지도 */
  .kr {
    fill: #dce8f4;
    stroke: #9ab4cc;
    stroke-width: 1;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  /* 노선 배경선 */
  .rt-group path {
    fill: none;
    stroke: rgba(27, 79, 138, 0.18);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* 흐름 대시 */
  .flow {
    fill: none;
    stroke: #1b4f8a;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 8 5;
  }
  .f1 { animation: flow 1.6s linear infinite; }
  .f2 { animation: flow 1.4s linear infinite; animation-delay: -0.5s; }
  .f3 { animation: flow 1.8s linear infinite; animation-delay: -1.1s; }

  @keyframes flow {
    to { stroke-dashoffset: -26; }
  }

  /* 일반 도시 도트 */
  .cdot {
    fill: #1b4f8a;
    opacity: 0.5;
  }

  /* 도시 레이블 */
  .lbl {
    font-family: 'Pretendard', -apple-system, sans-serif;
    font-size: 10px;
    font-weight: 600;
    fill: #1a2840;
    text-anchor: middle;
    paint-order: stroke fill;
    stroke: white;
    stroke-width: 3px;
    stroke-linejoin: round;
  }
  .hub-lbl {
    font-size: 11px;
    font-weight: 700;
    fill: #1b4f8a;
  }
  .lbl-right { text-anchor: start;  dominant-baseline: middle; }
  .lbl-left  { text-anchor: end;    dominant-baseline: middle; }
  .lbl-top   { dominant-baseline: auto; }

  /* 트럭 */
  .truck {
    fill: #1b4f8a;
    offset-rotate: auto;
    will-change: offset-distance;
  }
  .t1 {
    offset-path: path("M231,173 C228,215 218,270 207,336 C240,341 272,345 301,349");
    animation: drive 8s ease-in-out infinite alternate;
  }
  .t2 {
    offset-path: path("M245,148 L231,173 C265,215 295,245 325,271 L326,341 L366,344");
    animation: drive 10s ease-in-out infinite alternate;
    animation-delay: -3s;
  }
  .t3 {
    offset-path: path("M231,173 C265,215 295,245 325,271 C315,305 307,328 301,349");
    animation: drive 7s ease-in-out infinite alternate;
    animation-delay: -5s;
  }

  @keyframes drive {
    0%   { offset-distance: 0%;   }
    100% { offset-distance: 100%; }
  }

  @media (max-width: 600px) {
    .tr-frame { max-width: 100%; }
  }
</style>
