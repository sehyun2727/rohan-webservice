---
import { services } from '../../data/services.js';

const icons: Record<string, string> = {
  coldchain: `<svg width="40" height="40" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect x="2" y="12" width="26" height="20" rx="3" stroke="currentColor" stroke-width="2.2"/>
    <path d="M28 17h9l4 9v6H28V17z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
    <circle cx="10" cy="34" r="4" stroke="currentColor" stroke-width="2.2"/>
    <circle cx="34" cy="34" r="4" stroke="currentColor" stroke-width="2.2"/>
    <line x1="6" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="6" y1="25" x2="14" y2="25" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
  </svg>`,
  '3pl': `<svg width="40" height="40" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M4 20L22 8l18 12v20H4V20z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
    <rect x="18" y="28" width="8" height="12" rx="1.5" stroke="currentColor" stroke-width="2.2"/>
    <rect x="9" y="24" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.8"/>
    <rect x="29" y="24" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.8"/>
  </svg>`,
  storage: `<svg width="40" height="40" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <line x1="22" y1="4" x2="22" y2="40" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
    <line x1="4" y1="22" x2="40" y2="22" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
    <line x1="8.69" y1="8.69" x2="35.31" y2="35.31" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
    <line x1="35.31" y1="8.69" x2="8.69" y2="35.31" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
    <circle cx="22" cy="22" r="5" stroke="currentColor" stroke-width="2.2"/>
  </svg>`,
};

const topColors: Record<string, string> = {
  coldchain: 'var(--color-accent)',
  '3pl':     'var(--color-point)',
  storage:   'var(--color-primary-light)',
};
---

<section class="services-section section" aria-label="서비스">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <span class="section-label">Services</span>
      <h2 class="section-title">사업 영역</h2>
      <p class="section-desc">
        콜드체인 전 과정을 직접 운영합니다.<br />
        운송부터 보관·대행까지 원스톱으로 제공합니다.
      </p>
    </div>

    <div class="svc-grid">
      {services.map((s, i) => (
        <a href={`/services#${s.id}`} class={`svc-card svc-card--${s.id}`}
           data-aos="fade-up" data-aos-delay={i * 100}
           style={`--top-color: ${topColors[s.id]}`}>
          <div class="svc-card__top-bar" aria-hidden="true"></div>
          <div class="svc-card__icon" set:html={icons[s.id]} />
          <div class="svc-card__body">
            <span class="svc-card__en en">{s.titleEn}</span>
            <h3 class="svc-card__title">{s.title}</h3>
            <p class="svc-card__summary">{s.summary}</p>
          </div>
          <span class="svc-card__arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            자세히 보기
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: var(--color-bg-subtle);
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .svc-card {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 0 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid var(--color-border);
    transition: transform var(--transition), box-shadow var(--transition);
    overflow: hidden;
    text-decoration: none;
  }

  .svc-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .svc-card__top-bar {
    height: 4px;
    margin-inline: -2rem;
    background: var(--top-color);
    margin-bottom: 0.5rem;
  }

  .svc-card__icon {
    width: 52px;
    height: 52px;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: background var(--transition), color var(--transition);
  }

  .svc-card:hover .svc-card__icon {
    background: var(--top-color);
    color: #fff;
  }

  .svc-card__body { flex: 1; }

  .svc-card__en {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.35rem;
  }

  .svc-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .svc-card__summary {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .svc-card__arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: auto;
    transition: gap var(--transition), color var(--transition);
  }

  .svc-card:hover .svc-card__arrow {
    gap: 0.6rem;
    color: var(--color-primary-dark);
  }

  @media (min-width: 601px) and (max-width: 900px) {
    .svc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .svc-card:last-child { grid-column: 1 / -1; max-width: 480px; margin-inline: auto; width: 100%; }
  }

  @media (max-width: 600px) {
    .svc-grid { grid-template-columns: 1fr; }
  }
</style>
