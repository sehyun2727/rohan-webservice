---
import { company } from '../../data/company.js';

const currentYear = new Date().getFullYear();

const stats = [
  { value: '약 20대', label: '직영 냉동탑차',   sub: '5t ~ 11t 전 차종' },
  { value: '3개소',   label: '직영 물류센터',   sub: '안성 · 칠곡 · 진주' },
  { value: `${currentYear - company.founded}년+`, label: '물류 경험', sub: `${company.founded}년 설립` },
  { value: '3가지',   label: '온도대 운용',     sub: '냉동 · 냉장 · 상온' },
];
---

<div class="stats-strip" aria-label="핵심 지표">
  <div class="container stats-strip__grid">
    {stats.map((s, i) => (
      <div class="stats-strip__item" data-aos="fade-up" data-aos-delay={i * 80}>
        <span class="stats-strip__value">{s.value}</span>
        <span class="stats-strip__label">{s.label}</span>
        <span class="stats-strip__sub">{s.sub}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .stats-strip {
    background: #fff;
    padding-block: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .stats-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .stats-strip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    border-right: 1px solid var(--color-border);
    position: relative;
  }

  .stats-strip__item:last-child { border-right: none; }

  .stats-strip__item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 40px;
    height: 2px;
    background: var(--color-point);
    border-radius: 2px;
    transition: transform 0.3s ease;
  }

  .stats-strip__item:hover::after { transform: translateX(-50%) scaleX(1); }

  .stats-strip__value {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 900;
    color: var(--color-point);
    line-height: 1;
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }

  .stats-strip__label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .stats-strip__sub {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .stats-strip__grid { grid-template-columns: repeat(2, 1fr); }
    .stats-strip__item:nth-child(2) { border-right: none; }
    .stats-strip__item:nth-child(1),
    .stats-strip__item:nth-child(2) { border-bottom: 1px solid var(--color-border); }
  }

  @media (max-width: 400px) {
    .stats-strip__grid { grid-template-columns: 1fr; }
    .stats-strip__item { border-right: none; border-bottom: 1px solid var(--color-border); }
    .stats-strip__item:last-child { border-bottom: none; }
  }
</style>
