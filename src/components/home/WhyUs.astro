---
const reasons = [
  {
    num: '01',
    heading: '모든 차량을 직접 운영합니다',
    desc: '외주 없이 직영 차량·인력만으로 운영합니다. 책임 소재가 명확하고 서비스 품질을 처음부터 끝까지 직접 관리합니다.',
    features: ['직영 냉동탑차 약 20대 보유', '전담 드라이버 직접 고용', '실시간 운행·온도 모니터링'],
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="22" width="38" height="26" rx="3"/>
      <path d="M40 30h14l8 14v8H40V30z"/>
      <circle cx="14" cy="52" r="6"/>
      <circle cx="50" cy="52" r="6"/>
      <path d="M8 34h16M8 40h12"/>
      <path d="M20 14l12-6 12 6"/>
      <path d="M32 8v10"/>
    </svg>`,
    accent: 'var(--color-primary)',
  },
  {
    num: '02',
    heading: '전 온도대를 한 번에 대응합니다',
    desc: '냉동·냉장·상온을 단일 파트너로 처리합니다. 여러 업체에 나눠 맡길 필요 없이 로한물류 하나로 해결하세요.',
    features: ['냉동 -18°C 이하 유지', '냉장 0~10°C 정밀 관리', '상온 혼재 운송 가능'],
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="32" cy="32" r="26"/>
      <line x1="32" y1="6" x2="32" y2="58"/>
      <line x1="6" y1="32" x2="58" y2="32"/>
      <line x1="13" y1="13" x2="51" y2="51"/>
      <line x1="51" y1="13" x2="13" y2="51"/>
      <circle cx="32" cy="32" r="6" fill="currentColor" stroke="none" opacity="0.15"/>
      <circle cx="32" cy="32" r="6"/>
    </svg>`,
    accent: 'var(--color-point)',
  },
  {
    num: '03',
    heading: '전국 거점으로 빠르게 배송합니다',
    desc: '안성(수도권)과 칠곡(영남) 직영 허브를 중심으로 전국 협력 네트워크를 운영합니다. 주요 도시 당일·익일 배송을 실현합니다.',
    features: ['안성 수도권 직영 거점', '칠곡 영남 환적 거점', '전국 협력망 익일 배송'],
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M32 6C19 6 10 16 10 28c0 18 22 30 22 30s22-12 22-30C54 16 45 6 32 6z"/>
      <circle cx="32" cy="28" r="7"/>
      <path d="M10 28h6M48 28h6M32 6v6M32 50v6"/>
    </svg>`,
    accent: 'var(--color-accent)',
  },
];
---

<section class="whyus section" aria-label="왜 로한물류인가">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <span class="section-label">Why Rohan</span>
      <h2 class="section-title">왜 로한물류인가요?</h2>
      <p class="section-desc">
        단순 운송을 넘어 화주사의 물류 파트너가 됩니다.<br />
        직영 운영 원칙으로 품질과 책임을 직접 보장합니다.
      </p>
    </div>

    <div class="whyus__list">
      {reasons.map((r, i) => (
        <div class={`whyus__row ${i % 2 === 1 ? 'whyus__row--reverse' : ''}`}>

          <div class="whyus__visual" data-aos={i % 2 === 0 ? 'fade-right' : 'fade-left'} style={`--accent: ${r.accent}`}>
            <span class="whyus__num">{r.num}</span>
            <div class="whyus__icon" set:html={r.icon} />
          </div>

          <div class="whyus__content" data-aos={i % 2 === 0 ? 'fade-left' : 'fade-right'} data-aos-delay="100">
            <h3 class="whyus__heading">{r.heading}</h3>
            <p class="whyus__desc">{r.desc}</p>
            <ul class="whyus__features">
              {r.features.map((f) => (
                <li>{f}</li>
              ))}
            </ul>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .whyus {
    background: var(--color-bg-subtle);
  }

  .whyus__list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 3.5rem;
  }

  .whyus__row {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: #fff;
    transition: box-shadow var(--transition);
  }

  .whyus__row:hover { box-shadow: var(--shadow-lg); }

  .whyus__row--reverse {
    grid-template-columns: 1.6fr 1fr;
  }

  .whyus__row--reverse .whyus__visual { order: 2; }
  .whyus__row--reverse .whyus__content { order: 1; }

  /* Visual panel */
  .whyus__visual {
    background: var(--color-bg-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    gap: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .whyus__visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 70%);
  }

  .whyus__num {
    font-size: 4.5rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    opacity: 0.9;
    font-family: var(--font-en);
    position: relative;
    z-index: 1;
  }

  .whyus__icon {
    width: 72px;
    height: 72px;
    color: rgba(255,255,255,0.65);
    position: relative;
    z-index: 1;
  }

  .whyus__icon svg { width: 100%; height: 100%; }

  /* Content panel */
  .whyus__content {
    padding: 3rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .whyus__heading {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 800;
    color: var(--color-text);
    line-height: 1.35;
  }

  .whyus__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.85;
  }

  .whyus__features {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
  }

  .whyus__features li {
    font-size: 0.85rem;
    color: var(--color-text);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .whyus__features li::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-point);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .whyus__row,
    .whyus__row--reverse {
      grid-template-columns: 1fr;
    }

    .whyus__row--reverse .whyus__visual { order: 0; }
    .whyus__row--reverse .whyus__content { order: 0; }

    .whyus__visual { padding: 2.5rem; flex-direction: row; justify-content: flex-start; gap: 2rem; }
    .whyus__num { font-size: 3rem; }
    .whyus__icon { width: 52px; height: 52px; }
    .whyus__content { padding: 2rem 2.5rem; }
  }

  @media (max-width: 480px) {
    .whyus__content { padding: 1.75rem; }
    .whyus__visual { padding: 2rem 1.75rem; }
  }
</style>
