---
import { warehouseCommonFeatures } from '../../data/warehouses.js';

const icons: Record<string, string> = {
  temp: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 6v18M20 30a6 6 0 100-12 6 6 0 000 12z"/>
    <path d="M20 6a2 2 0 110-4 2 2 0 010 4z" fill="currentColor" stroke="none" opacity=".3"/>
    <path d="M14 10h-3M14 16h-4M14 22h-3M26 10h3M26 16h4M26 22h3"/>
  </svg>`,
  monitor: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <rect x="4" y="6" width="32" height="22" rx="3"/>
    <path d="M14 34h12M20 28v6"/>
    <path d="M10 18l5 5 5-8 5 5 5-3"/>
  </svg>`,
  forklift: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 30V10h10l8 12v8H4z"/>
    <path d="M22 22h10v8H22z"/>
    <path d="M32 22V10"/>
    <circle cx="10" cy="33" r="3"/>
    <circle cx="26" cy="33" r="3"/>
    <path d="M4 20h14"/>
  </svg>`,
  hygiene: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 4l14 6v10c0 8-6 14-14 16C12 34 6 28 6 20V10l14-6z"/>
    <path d="M14 20l4 4 8-8"/>
  </svg>`,
};
---

<section class="wh-features" aria-label="공통 보관 시설 특징">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <span class="section-label">Facility Standards</span>
      <h2 class="section-title">공통 보관 기준</h2>
      <p class="section-desc">안성·칠곡·함안·진주 4개 거점에 공통 적용되는 보관·운영 기준입니다.</p>
    </div>

    <div class="wh-features__grid">
      {warehouseCommonFeatures.map((f, i) => (
        <div class="wh-features__card" data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="wh-features__icon" set:html={icons[f.icon]} />
          <strong class="wh-features__title">{f.title}</strong>
          <p class="wh-features__desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .wh-features {
    background: var(--color-bg-dark);
    padding-block: var(--section-py);
  }

  .wh-features .section-label { color: var(--color-accent); }
  .wh-features .section-title { color: #fff; }
  .wh-features .section-desc  { color: rgba(255,255,255,0.5); }

  .wh-features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .wh-features__card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: background var(--transition), border-color var(--transition);
  }

  .wh-features__card:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.15);
  }

  .wh-features__icon {
    width: 40px;
    height: 40px;
    color: var(--color-accent);
  }

  .wh-features__icon svg { width: 100%; height: 100%; }

  .wh-features__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.4;
  }

  .wh-features__desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .wh-features__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .wh-features__grid { grid-template-columns: 1fr; }
  }
</style>
