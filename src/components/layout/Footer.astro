---
import { company } from '../../data/company.js';
---

<footer class="footer">
  <div class="container footer__inner">

    <div class="footer__brand">
      <a href="/" aria-label="로한물류 홈">
        <img src="/logo.png" alt="로한물류" class="footer__logo" />
      </a>
      <p class="footer__tagline">{company.tagline}</p>
    </div>

    <nav class="footer__nav" aria-label="푸터 네비게이션">
      <a href="/about">회사소개</a>
      <a href="/services">서비스</a>
      <a href="/vehicles">차량소개</a>
      <a href="/warehouses">창고소개</a>
      <a href="/quote">견적문의</a>
    </nav>

    <address class="footer__info">
      <strong>{company.name}</strong>&nbsp; 대표: {company.ceo}<br />
      {company.address} {company.addressDetail}<br />
      대표전화&nbsp;
      <a href={`tel:${company.tel.replace(/-/g, '')}`}>{company.tel}</a>
      &nbsp;·&nbsp; 팩스 {company.fax}
      &nbsp;·&nbsp; 운영팀장&nbsp;
      <a href={`tel:${company.mobile.replace(/-/g, '')}`}>{company.mobile}</a><br />
      메일&nbsp;
      <a href={`mailto:${company.email}`}>{company.email}</a>
      &nbsp;·&nbsp; 사업자등록번호: {company.businessNumber}
    </address>

  </div>

  <div class="footer__bottom">
    <p>© {new Date().getFullYear()} (주)로한물류. All rights reserved.</p>
    <nav class="footer__legal" aria-label="법적 고지">
      <a href="/privacy">개인정보처리방침</a>
      <span aria-hidden="true">|</span>
      <a href="/email-policy">이메일무단수집거부</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-dark);
    color: rgba(255, 255, 255, 0.75);
    margin-top: 0;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 3rem;
    padding-block: 3rem;
    align-items: start;
  }

  /* Brand */
  .footer__logo {
    height: 36px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  .footer__logo-fallback {
    font-size: 1rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.85);
    display: none;
  }

  .footer__tagline {
    font-family: var(--font-en);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 0.5rem;
    line-height: 1;
  }

  /* Nav */
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    padding-top: 0.25rem;
  }

  .footer__nav a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    transition: color var(--transition);
  }

  .footer__nav a:hover {
    color: #fff;
  }

  /* Info */
  .footer__info {
    font-size: 0.82rem;
    line-height: 1.9;
    font-style: normal;
    text-align: right;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__info strong {
    color: #fff;
  }

  .footer__info a {
    color: rgba(255, 255, 255, 0.65);
    transition: color var(--transition);
  }

  .footer__info a:hover {
    color: var(--color-accent);
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-block: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
  }

  .footer__legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__legal a {
    color: rgba(255, 255, 255, 0.35);
    transition: color var(--transition);
  }

  .footer__legal a:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .footer__legal span {
    color: rgba(255, 255, 255, 0.15);
  }

  /* Tablet */
  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__info {
      text-align: left;
      grid-column: 1 / -1;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__nav {
      justify-content: flex-start;
    }
  }
</style>
