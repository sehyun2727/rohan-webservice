---
// 경영이념 내용을 여기에 수정하세요
const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 4l3.5 7 7.7 1.1-5.6 5.4 1.3 7.7L20 21.8l-6.9 3.6 1.3-7.7L8.8 12.1 16.5 11z"/>
      <circle cx="20" cy="28" r="8"/>
      <path d="M16 28l3 3 5-5"/>
    </svg>`,
    keyword: '신뢰',
    desc: '[경영이념 설명을 입력해 주세요]',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="20" cy="20" r="15"/>
      <path d="M20 10v10l6 4"/>
    </svg>`,
    keyword: '신속',
    desc: '[경영이념 설명을 입력해 주세요]',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 4l13 7v10l-13 7L7 21V11z"/>
      <path d="M20 4v24M7 11l13 7 13-7"/>
    </svg>`,
    keyword: '안전',
    desc: '[경영이념 설명을 입력해 주세요]',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 30c0-8 5-14 10-14s10 6 10 14"/>
      <path d="M20 16V8"/>
      <path d="M14 10l6-4 6 4"/>
      <circle cx="20" cy="33" r="3"/>
    </svg>`,
    keyword: '혁신',
    desc: '[경영이념 설명을 입력해 주세요]',
  },
];
---

<section class="philosophy" aria-label="경영이념">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Our Values</span>
      <h2 class="section-title">경영이념</h2>
      <p class="section-desc">
        <!-- 경영이념 소개 문구를 입력해 주세요 -->
        [경영이념 소개 문구를 입력해 주세요.]
      </p>
    </div>

    <div class="philosophy__grid">
      {values.map((v, i) => (
        <div class="philosophy__card" data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="philosophy__icon" set:html={v.icon} />
          <h3 class="philosophy__keyword">{v.keyword}</h3>
          <p class="philosophy__desc">{v.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .philosophy {
    padding-block: var(--section-py);
    background: #fff;
  }

  .philosophy__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .philosophy__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-top: 4px solid var(--color-primary);
    transition: box-shadow var(--transition), transform var(--transition);
    background: #fff;
  }

  .philosophy__card:nth-child(2) { border-top-color: var(--color-point); }
  .philosophy__card:nth-child(3) { border-top-color: var(--color-accent); }
  .philosophy__card:nth-child(4) { border-top-color: var(--color-primary-light); }

  .philosophy__card:hover {
    box-shadow: 0 8px 32px rgba(27, 79, 138, 0.12);
    transform: translateY(-6px);
  }

  .philosophy__icon {
    width: 48px;
    height: 48px;
    color: var(--color-primary);
    margin-bottom: 1.1rem;
  }

  .philosophy__card:nth-child(2) .philosophy__icon { color: var(--color-point); }
  .philosophy__card:nth-child(3) .philosophy__icon { color: var(--color-accent); }

  .philosophy__icon svg {
    width: 100%;
    height: 100%;
  }

  .philosophy__keyword {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.65rem;
  }

  .philosophy__desc {
    font-size: 0.83rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    word-break: keep-all;
  }

  @media (max-width: 900px) {
    .philosophy__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .philosophy__grid { grid-template-columns: 1fr; }
  }
</style>
