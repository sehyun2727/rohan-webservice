---
const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="20" cy="13" r="6"/>
      <path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12"/>
    </svg>`,
    keyword: '개인존중',
    en: 'Respect for the individual',
    desc: '구성원 각자가 성공하고 행복할 수 있도록 존중합니다. 정규직원·기사·협력사 담당자 모두를 소중한 파트너로 여기는 문화를 실천합니다.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 6l2.5 5 5.5.8-4 3.9.9 5.5L20 18.8l-4.9 2.4.9-5.5-4-3.9 5.5-.8z"/>
      <path d="M10 30h20M13 35h14"/>
    </svg>`,
    keyword: '고객 최우선',
    en: 'Best possible service to customers',
    desc: '고객에게 가능한 최선의 서비스를 제공합니다. 더 나은 물류 서비스를 위해 끊임없이 연구하고 노력하며 고객 만족을 최우선 가치로 삼습니다.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 5l4 9 10 1.4-7.2 7 1.7 9.9L20 27.5l-8.5 4.8 1.7-9.9L6 15.4 16 14z"/>
    </svg>`,
    keyword: '탁월성 추구',
    en: 'Pursue true value & excellence',
    desc: '사회·국가·인류에 이로운 참된 가치를 추구합니다. 완벽한 수준을 향한 끊임없는 도전과 완전한 서비스·업무처리를 목표로 합니다.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 5l13 5v11c0 7.18-5.52 13.9-13 15-7.48-1.1-13-7.82-13-15V10z"/>
      <path d="M14 20l4 4 8-8"/>
    </svg>`,
    keyword: '안전·건강·환경',
    en: 'Safety, Health, Green',
    desc: '구성원의 안전·건강·행복을 최우선으로 중시합니다. 지속 가능한 미래를 위해 환경을 소중히 여기는 친환경 물류를 실천합니다.',
  },
];
---

<section class="philosophy" aria-label="경영이념">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Our Values</span>
      <h2 class="section-title">경영이념</h2>
      <p class="section-desc">
        (주)로한물류는 사람 중심의 경영과 고객 신뢰를 바탕으로<br />
        네 가지 핵심 가치를 실천하며 성장해 왔습니다.
      </p>
    </div>

    <div class="philosophy__grid">
      {values.map((v, i) => (
        <div class="philosophy__card" data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="philosophy__icon" set:html={v.icon} />
          <h3 class="philosophy__keyword">{v.keyword}</h3>
          <p class="philosophy__en">{v.en}</p>
          <p class="philosophy__desc">{v.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .philosophy {
    padding-block: var(--section-py);
    background: #fff;
  }

  .philosophy__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .philosophy__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-top: 4px solid var(--color-primary);
    transition: box-shadow var(--transition), transform var(--transition);
    background: #fff;
  }

  .philosophy__card:nth-child(2) { border-top-color: var(--color-point); }
  .philosophy__card:nth-child(3) { border-top-color: var(--color-accent); }
  .philosophy__card:nth-child(4) { border-top-color: var(--color-primary-light); }

  .philosophy__card:hover {
    box-shadow: 0 8px 32px rgba(27, 79, 138, 0.12);
    transform: translateY(-6px);
  }

  .philosophy__icon {
    width: 48px;
    height: 48px;
    color: var(--color-primary);
    margin-bottom: 1.1rem;
  }

  .philosophy__card:nth-child(2) .philosophy__icon { color: var(--color-point); }
  .philosophy__card:nth-child(3) .philosophy__icon { color: var(--color-accent); }

  .philosophy__icon svg {
    width: 100%;
    height: 100%;
  }

  .philosophy__keyword {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .philosophy__en {
    font-family: var(--font-en);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .philosophy__desc {
    font-size: 0.83rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    word-break: keep-all;
  }

  @media (max-width: 900px) {
    .philosophy__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .philosophy__grid { grid-template-columns: 1fr; }
  }
</style>
