---
import { company } from '../../data/company.js';

const career = [
  { year: '1997', desc: '경북대학교 경영학과 졸업' },
  { year: '1999', desc: '컴퓨터·인터넷 IT 업계 근무' },
  { year: '2001', desc: '구미잡(주) 설립 및 운영' },
  { year: '2006', desc: '신선물류 전문기업 근무' },
  { year: '2007', desc: '(주)로한물류 설립 · 대표이사 취임 (현재)' },
];
---

<section class="ceo-profile" aria-label="대표이사 소개">
  <div class="container">
    <div class="section-header">
      <span class="section-label">CEO Profile</span>
      <h2 class="section-title">대표이사 소개</h2>
    </div>

    <div class="ceo-profile__card" data-aos="fade-up">
      <div class="ceo-profile__info">
        <p class="ceo-profile__name">{company.ceo}</p>
        <p class="ceo-profile__title">대표이사</p>
        <p class="ceo-profile__bio">
          경북대학교 경영학 전공 후 IT 업계 창업을 거쳐, 신선물류 현장에서 쌓은 경험을 바탕으로
          2007년 (주)로한물류를 설립하였습니다.<br /><br />
          설립 이래 홈플러스·이마트·롯데마트·BHC 등 전국 80여 개 업체와의 신뢰를 쌓으며,
          수도권·영남·호남권을 아우르는 전국 콜드체인 네트워크를 구축해 왔습니다.
          앞으로도 혁신과 책임감을 바탕으로 고객과 함께 성장하는 물류기업을 만들어 가겠습니다.
        </p>
      </div>

      <div class="ceo-profile__career">
        <h3 class="ceo-profile__career-title">주요 약력</h3>
        <ul class="ceo-profile__career-list">
          {career.map((c) => (
            <li>
              <span class="ceo-profile__year">{c.year}</span>
              <span class="ceo-profile__desc">{c.desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .ceo-profile {
    padding-block: var(--section-py);
    background: var(--color-bg-subtle);
  }

  .ceo-profile__card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2.5rem;
    margin-top: 2rem;
  }

  .ceo-profile__name {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .ceo-profile__title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    letter-spacing: 0.04em;
  }

  .ceo-profile__bio {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .ceo-profile__career-title {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .ceo-profile__career-list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .ceo-profile__career-list li {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    font-size: 0.9rem;
  }

  .ceo-profile__year {
    font-weight: 700;
    color: var(--color-primary);
    min-width: 42px;
    flex-shrink: 0;
  }

  .ceo-profile__desc {
    color: var(--color-text);
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .ceo-profile__card {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem;
    }
  }
</style>
